<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= mapToken %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="row">

  <!-- TITLE -->
  <div class="col-12 col-md-8 offset-md-2">
    <h3 class="mb-3">
      <b><%= listing.title %></b>
    </h3>
  </div>

  <!-- LISTING CARD -->
  <div class="card show-card col-12 col-md-8 offset-md-2 listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="listing_image"
    />

    <div class="card-body">
      <p class="card-text">
        Owned by <i><%= listing.owner.username %></i>
      </p>

      <p class="card-text">
        <i><%= listing.description %></i>
      </p>

      <p class="card-text">
        &#x20B9; <%= listing.price %>
      </p>

      <p class="card-text">
        <%= listing.location %>
      </p>

      <p class="card-text">
        <%= listing.country %>
      </p>
    </div>
  </div>

  <!-- EDIT DELETE -->
  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>

  <div class="col-12 col-md-8 offset-md-2 mt-3 d-flex gap-3 flex-wrap">
    <a
      class="btn btn-dark"
      href="/listings/<%= listing._id %>/edit"
    >
      Edit
    </a>

    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=DELETE"
    >
      <button class="btn btn-dark">
        Delete
      </button>
    </form>
  </div>

  <% } %>

  <!-- REVIEW FORM -->
  <% if(currUser) { %>

  <div class="col-12 col-md-8 offset-md-2">
    <hr class="mt-4" />

    <h4>Leave a Review</h4>

    <form
      novalidate
      class="needs-validation"
      action="/listings/<%= listing._id %>/reviews"
      method="POST"
    >

      <!-- RATING -->
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">
          Rating
        </label>

        <fieldset class="starability-slot">
          <input
            type="radio"
            id="no-rate"
            class="input-no-rate"
            name="review[rating]"
            value="1"
            checked
            aria-label="No rating."
          />

          <input
            type="radio"
            id="first-rate1"
            name="review[rating]"
            value="1"
          />
          <label for="first-rate1" title="Terrible">
            1 star
          </label>

          <input
            type="radio"
            id="first-rate2"
            name="review[rating]"
            value="2"
          />
          <label for="first-rate2" title="Not good">
            2 stars
          </label>

          <input
            type="radio"
            id="first-rate3"
            name="review[rating]"
            value="3"
          />
          <label for="first-rate3" title="Average">
            3 stars
          </label>

          <input
            type="radio"
            id="first-rate4"
            name="review[rating]"
            value="4"
          />
          <label for="first-rate4" title="Very good">
            4 stars
          </label>

          <input
            type="radio"
            id="first-rate5"
            name="review[rating]"
            value="5"
          />
          <label for="first-rate5" title="Amazing">
            5 stars
          </label>
        </fieldset>
      </div>

      <!-- COMMENT -->
      <div class="mb-3 mt-3">
        <label
          class="form-label"
          for="comment"
        >
          Comment
        </label>

        <textarea
          required
          class="form-control"
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
        ></textarea>

        <div class="invalid-feedback">
          Please comment something
        </div>
      </div>

      <!-- BUTTON -->
      <div class="mb-3 mt-3">
        <button class="btn btn-dark">
          Submit
        </button>
      </div>

    </form>
  </div>

  <% } %>

  <!-- REVIEWS -->
  <% if(listing.reviews.length > 0) { %>

  <div class="col-12 col-md-8 offset-md-2">
    <hr />

    <h4>All Reviews</h4>

    <div class="row">

      <% for(let review of listing.reviews){ %>

      <div class="card col-12 col-md-5 ms-md-3 mb-3">
        <div class="card-body">

          <h5>
            @<%= review.author.username %>
          </h5>

          <p
            class="starability-result card-text"
            data-rating="<%= review.rating %>"
          ></p>

          <p>
            <%= review.comment %>
          </p>

        </div>

        <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>

        <form
          class="mb-3 ms-3"
          method="POST"
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
        >
          <button class="btn btn-sm btn-dark">
            Delete
          </button>
        </form>

        <% } %>

      </div>

      <% } %>

    </div>
  </div>

  <% } %>

  <!-- MAP -->
  <div class="col-12 col-md-8 offset-md-2 mb-3">
    <hr />

    <h3>Where you will be</h3>

    <div id="map"></div>
  </div>

</div>

<script src="/js/map.js"></script>