<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2 mb-3">
    <h3>Edit your listing</h3>
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      enctype="multipart/form-data"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          required
          class="form-control"
          type="text"
          id="title"
          name="listing[title]"
          value="<%= listing.title %>"
        />
        <div class="invalid-feedback">Please Enter Title</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          required
          class="form-control"
          id="description"
          name="listing[description]"
        >
<%= listing.description %></textarea
        >
        <div class="invalid-feedback">Please Enter Description</div>
      </div>
      <div class="mb-3">
        <div class="mb-3">
          <p class="mb-1">Current Image</p>
          <img src="<%= originalImageUrl %>" alt="listing_image" class="img-thumbnail mb-2" />
        </div>
        <label for="image" class="form-label">Upload New Image</label>
        <input class="form-control" type="file" id="image" name="listing[image]" />
      </div>

      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input
          required
          class="form-control"
          type="text"
          id="country"
          name="listing[country]"
          value="<%= listing.country %>"
        />
        <div class="invalid-feedback">Country Name Should Be Valid</div>
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input required class="form-control" type="number" id="price" name="listing[price]" value="<%= listing.price %>" />
        <div class="invalid-feedback">Price Should be Valid</div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input required class="form-control" type="text" id="location" name="listing[location]" value="<%= listing.location %>" />
        <div class="invalid-feedback">Location Should Be Valid</div>
      </div>

      <button class="btn btn-dark mt-3">Edit</button>
    </form>
  </div>
</div>
